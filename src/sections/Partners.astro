---
const partnerGroups = [
  {
    title: "Structural and Building",
    partners: [
      { name: "ReNuTeq", href: "https://renuteq.com", logo: "/images/partners/renuteq.jpg", scale: 0.7 }
    ]
  },
  {
    title: "Energy and Infrastructure",
    partners: [
      { name: "Carbon DC", href: "https://carbondc.io", logo: "/images/partners/carbondc.png" },
      { name: "Ekoenergetyka", href: "https://ekoenergetyka.com/america/", logo: "/images/partners/eko-trans.webp" },
      { name: "HyWatts", href: "https://hywatts.com", logo: "/images/partners/hywatts.webp" }
    ]
  },
  {
    title: "Software and Driver Experience",
    partners: [
      { name: "ChargeMate", href: "https://chargemate.ai", logo: "/images/partners/chargemate.jpg" },
      { name: "Juice", href: "https://js.eco", logo: "/images/partners/juice.png" },
      { name: "Monta", href: "https://monta.com", logo: "/images/partners/monta.png" },
      { name: "WattsUp", href: "https://wattsupev.io/", logo: "/images/partners/wattsup.png" }
    ]
  }
];
---

<section class="partners section">
  <div class="container">
    <div class="partners__heading reveal">
      <p class="eyebrow">Partners</p>
      <h2>Built with the best.</h2>
      <p class="partners__lede">
        Built with partners across energy, infrastructure, software, and structure.
      </p>
    </div>

    <div class="partners__strip">
      {partnerGroups.map((group) => (
        <div class="partners__group">
          <p class="eyebrow eyebrow--plain partners__group-title">{group.title}</p>
          <div class="partners__group-logos">
            {group.partners.map((p) => (
              <a
                class="partners__logo"
                href={p.href}
                target="_blank"
                rel="noopener"
                aria-label={`${p.name} (opens in new tab)`}
                style={p.scale ? `--logo-scale: ${p.scale}` : undefined}
              >
                <picture>
                  {p.logoDark && <source srcset={p.logoDark} media="(prefers-color-scheme: dark)" />}
                  <img src={p.logo} alt={`${p.name} logo`} loading="lazy" />
                </picture>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="partners__cta reveal">
      <a class="btn-link" href="/partners">
        See all partners
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .partners__heading {
    max-width: 620px;
    margin-bottom: var(--space-7);
  }

  .partners__lede {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  .partners__strip {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: center;
    gap: var(--space-6) var(--space-9);
    padding: var(--space-7) var(--space-5);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .partners__group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .partners__group-title {
    margin: 0;
    color: var(--color-warm-deep);
  }

  .partners__group-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-5);
  }

  .partners__logo {
    --logo-scale: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-cream);
    border-radius: var(--radius-sm);
    padding: 8px 14px;
    opacity: 0.9;
    transition: opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard);
  }

  .partners__logo:hover {
    opacity: 1;
    transform: translateY(-1px);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }

  .partners__logo img {
    height: calc(32px * var(--logo-scale));
    width: auto;
    max-width: calc(150px * var(--logo-scale));
    object-fit: contain;
    display: block;
  }

  .partners__cta {
    margin-top: var(--space-7);
  }

  @media (max-width: 720px) {
    .partners__strip {
      gap: var(--space-6);
      padding: var(--space-6) var(--space-3);
    }

    .partners__group-logos {
      gap: var(--space-3);
    }

    .partners__logo {
      padding: 6px 10px;
    }

    .partners__logo img {
      height: calc(26px * var(--logo-scale));
    }
  }
</style>
