---
const partners = [
  { name: "Carbon DC", href: "https://carbondc.io", logo: "/images/partners/carbondc.png" },
  { name: "ChargeMate", href: "https://chargemate.ai", logo: "/images/partners/chargemate.jpg" },
  { name: "Ekoenergetyka", href: "https://ekoenergetyka.com/america/", logo: "/images/partners/eko-trans.webp" },
  { name: "HyWatts", href: "https://hywatts.com", logo: "/images/partners/hywatts.webp" },
  { name: "Juice", href: "https://js.eco", logo: "/images/partners/juice.png" },
  { name: "Monta", href: "https://monta.com", logo: "/images/partners/monta.png" },
  { name: "ReNuTeq", href: "https://renuteq.com", logo: "/images/partners/renuteq.jpg", scale: 0.7 },
  { name: "WattsUp", href: "https://wattsupev.io/", logo: "/images/partners/wattsup.png" }
];
---

<section class="partners section">
  <div class="container">
    <div class="partners__heading reveal">
      <p class="eyebrow">Partners</p>
      <h2>Built with the best.</h2>
      <p class="partners__lede">
        Built with trusted partners across energy, hardware, and technology.
      </p>
    </div>

    <div class="partners__strip">
      {partners.map((p) => (
        <a
          class:list={["partners__logo", !p.logoDark && "partners__logo--auto-dark"]}
          href={p.href}
          target="_blank"
          rel="noopener"
          aria-label={`${p.name} (opens in new tab)`}
          style={p.scale ? `--logo-scale: ${p.scale}` : undefined}
        >
          <picture>
            {p.logoDark && <source srcset={p.logoDark} media="(prefers-color-scheme: dark)" />}
            <img src={p.logo} alt={`${p.name} logo`} loading="lazy" />
          </picture>
        </a>
      ))}
    </div>

    <div class="partners__cta reveal">
      <a class="btn-link" href="/partners">
        See all partners
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .partners__heading {
    max-width: 620px;
    margin-bottom: var(--space-7);
  }

  .partners__lede {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
  }

  .partners__strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-7);
    padding: var(--space-7) var(--space-5);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .partners__logo {
    --logo-scale: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: calc(44px * var(--logo-scale));
    max-width: calc(180px * var(--logo-scale));
    filter: grayscale(1);
    opacity: 0.65;
    transition: filter var(--dur-fast) var(--ease-standard),
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }

  .partners__logo:hover {
    filter: grayscale(0);
    opacity: 1;
    transform: translateY(-1px);
  }

  .partners__logo img,
  .partners__logo picture {
    height: 100%;
    max-height: calc(44px * var(--logo-scale));
    width: auto;
    max-width: calc(180px * var(--logo-scale));
    object-fit: contain;
  }

  .partners__cta {
    margin-top: var(--space-7);
  }

  @media (prefers-color-scheme: dark) {
    .partners__logo--auto-dark {
      background: var(--color-cream);
      border-radius: var(--radius-sm);
      padding: 6px 12px;
      filter: none;
      opacity: 0.88;
    }

    .partners__logo--auto-dark:hover {
      opacity: 1;
      background: var(--color-white);
    }
  }

  @media (max-width: 720px) {
    .partners__strip {
      gap: var(--space-5);
      padding: var(--space-6) var(--space-3);
    }

    .partners__logo {
      height: calc(36px * var(--logo-scale));
    }

    .partners__logo img {
      max-height: calc(36px * var(--logo-scale));
    }
  }
</style>
