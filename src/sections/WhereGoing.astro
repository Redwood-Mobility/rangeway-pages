---
const states = [
  { name: "California", blurb: "The road climbs into the high desert." },
  { name: "Nevada", blurb: "A quiet valley threads between the ranges." },
  { name: "Texas", blurb: "The sky takes over where the plains begin." }
];
---

<section class="where section section-cream">
  <div class="container">
    <div class="where__heading reveal">
      <p class="eyebrow">Where We're Going</p>
      <h2>The first Rangeway locations are coming to California, Nevada, and Texas.</h2>
      <p class="where__lede">
        More routes will follow. Subscribe to Field Notes for first access to site announcements,
        format openings, and the stories behind them.
      </p>
    </div>

    <div class="where__states">
      {states.map((s) => (
        <article class="where__state reveal">
          <span class="where__state-num">/{String(states.indexOf(s) + 1).padStart(2, "0")}</span>
          <h3>{s.name}</h3>
          <p>{s.blurb}</p>
        </article>
      ))}
    </div>

    <div class="where__cta reveal">
      <a class="btn btn-primary" href="https://fieldnotes.rangewayev.com" target="_blank" rel="noopener">
        Subscribe to Field Notes
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .where__heading {
    max-width: 760px;
    margin-bottom: var(--space-8);
  }

  .where__heading h2 {
    text-wrap: balance;
  }

  .where__lede {
    margin-top: var(--space-4);
    color: var(--color-text-muted);
    font-size: 1.08rem;
    max-width: 62ch;
  }

  .where__states {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-7) 0;
  }

  .where__state {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .where__state-num {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: var(--color-warm-deep);
    font-weight: 600;
  }

  .where__state h3 {
    font-size: clamp(1.6rem, 2.4vw, 2rem);
    font-weight: 700;
  }

  .where__state p {
    color: var(--color-text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .where__cta {
    margin-top: var(--space-7);
  }

  @media (max-width: 900px) {
    .where__states {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
