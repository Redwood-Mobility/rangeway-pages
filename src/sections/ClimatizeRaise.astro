---
---

<section class="climatize section">
  <div class="container">
    <div class="climatize__inner reveal">
      <div class="climatize__copy">
        <p class="eyebrow">Now open</p>
        <h2>Build Rangeway Mojave with us.</h2>
        <p class="climatize__lede">
          Rangeway is raising capital on Climatize to build Rangeway Mojave, the first location in the network. The campaign is open to everyone, not just accredited investors. Anyone can invest in the first site, starting at the campaign minimum.
        </p>
      </div>

      <div class="climatize__cta">
        <a class="btn btn-warm" href="https://climatize.earth" target="_blank" rel="noopener">
          Invest in Mojave
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </a>
        <a class="btn-link" href="https://mojave.rangewayev.com" target="_blank" rel="noopener">
          Visit Rangeway Mojave
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .climatize {
    padding: clamp(72px, 9vw, 120px) 0;
    background: var(--surface-alt-strong);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }

  .climatize::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 85% 20%, rgba(244, 168, 85, 0.12), transparent 45%);
    pointer-events: none;
    z-index: -1;
  }

  .climatize__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  .climatize__copy h2 {
    margin-bottom: var(--space-4);
    text-wrap: balance;
  }

  .climatize__lede {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin: 0;
    max-width: 56ch;
  }

  .climatize__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .climatize__cta .btn-link {
    padding-left: 8px;
  }

  @media (max-width: 900px) {
    .climatize__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
