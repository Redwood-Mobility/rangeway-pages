---
---

<section class="recognition-strip">
  <div class="container">
    <div class="recognition-strip__inner reveal">
      <p class="eyebrow">Recognition</p>
      <div class="recognition-strip__items">
        <article>
          <span class="recognition-strip__label">Top emerging charge point operators</span>
          <span class="recognition-strip__source">Ohm Analytics · Q3 2025 US EV Charging Market Report</span>
        </article>
        <article>
          <span class="recognition-strip__label">Pepperdine Most Fundable Companies</span>
          <span class="recognition-strip__source">Quarter-finalist</span>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  .recognition-strip {
    padding: var(--space-7) 0;
    background: var(--surface-alt-strong);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .recognition-strip__inner {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  .recognition-strip .eyebrow {
    margin: 0;
  }

  .recognition-strip__items {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-7);
  }

  .recognition-strip article {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .recognition-strip__label {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--color-text);
    line-height: 1.3;
  }

  .recognition-strip__source {
    font-size: 0.88rem;
    color: var(--color-text-muted);
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .recognition-strip__inner {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .recognition-strip__items {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
  }
</style>
