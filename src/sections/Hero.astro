---
const desktopImage = "/images/hero-mountain-waystation.png";
const mobileImage = "/images/hero-mountain-waystation-mobile.png";
const heroAlt = "A Rangeway Waystation at dusk with sunset-lit mountains behind, lounge interior glowing through the glass facade, and a Rivian charging under the timber canopy";
---

<section class="hero">
  <div class="hero__media">
    <picture>
      <source media="(max-width: 720px)" srcset={mobileImage} />
      <img src={desktopImage} alt={heroAlt} fetchpriority="high" />
    </picture>
    <div class="hero__scrim"></div>
  </div>

  <div class="hero__inner container">
    <p class="eyebrow hero__eyebrow">America's First Hospitality-Driven EV Charging Network</p>
    <h1 class="hero__headline">Travel Farther, <br />Stop Better.</h1>
    <p class="hero__lede">
      Premium EV charging meets luxury hospitality. Every stop designed around you, not just your vehicle.
    </p>
    <div class="hero__ctas">
      <a class="btn btn-warm" href="#network">
        Discover the Network
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
      <a class="btn btn-ghost" href="/our-story">Our Story</a>
    </div>
  </div>

  <a class="hero__scroll" href="#positioning" aria-label="Scroll to next section">
    <span>Scroll</span>
    <span class="hero__scroll-line"></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    color: var(--color-white);
    overflow: hidden;
    isolation: isolate;
    background: var(--color-ink);
    padding: 148px 0 96px;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
  }

  .hero__scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(120deg, rgba(17, 13, 12, 0.82) 0%, rgba(17, 13, 12, 0.35) 45%, rgba(17, 13, 12, 0.78) 100%),
      radial-gradient(circle at 18% 20%, rgba(244, 168, 85, 0.22), transparent 38%);
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 820px;
  }

  .hero__eyebrow {
    color: var(--color-white);
    opacity: 0.92;
    margin: 0 0 var(--space-5);
  }

  .hero__eyebrow::before {
    background: var(--color-warm);
    opacity: 1;
  }

  .hero__headline {
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: var(--fs-display);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    margin: 0 0 var(--space-5);
    max-width: 14ch;
    text-wrap: balance;
  }

  .hero__lede {
    margin: 0 0 var(--space-7);
    font-size: clamp(1.1rem, 1.6vw, 1.26rem);
    line-height: 1.65;
    max-width: 560px;
    color: rgba(255, 255, 255, 0.84);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    z-index: 2;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .hero__scroll-line {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.4);
    animation: heroBob 2.6s var(--ease-standard) infinite;
    transform-origin: top;
  }

  @keyframes heroBob {
    0%, 100% {
      transform: scaleY(1);
    }
    50% {
      transform: scaleY(0.4);
    }
  }

  @media (max-width: 720px) {
    .hero__scroll {
      display: none;
    }
    .hero__headline br {
      display: none;
    }
    .hero__media img {
      object-position: center center;
    }
  }
</style>
