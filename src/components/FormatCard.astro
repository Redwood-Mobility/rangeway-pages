---
interface Props {
  name: string;
  tagline: string;
  description: string;
  image: string;
  imageAlt: string;
  href: string;
  pill?: string;
}
const { name, tagline, description, image, imageAlt, href, pill } = Astro.props;
---

<a class="fmt-card reveal" href={href}>
  <div class="fmt-card__media">
    <img src={image} alt={imageAlt} loading="lazy" />
    {pill && <span class="fmt-card__pill">{pill}</span>}
  </div>
  <div class="fmt-card__body">
    <p class="fmt-card__eyebrow">{tagline}</p>
    <h3>{name}</h3>
    <p class="fmt-card__description">{description}</p>
    <div class="fmt-card__foot">
      <span class="arrow-link">
        Learn more
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </span>
    </div>
  </div>
</a>

<style>
  .fmt-card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: var(--surface-raised);
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    color: var(--color-text);
    transition: transform var(--dur-med) var(--ease-standard),
      box-shadow var(--dur-med) var(--ease-standard);
  }

  .fmt-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 36px 90px rgba(0, 0, 0, 0.16);
    color: var(--color-text);
  }

  .fmt-card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--surface-alt);
  }

  .fmt-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-standard);
  }

  .fmt-card:hover .fmt-card__media img {
    transform: scale(1.04);
  }

  .fmt-card__pill {
    position: absolute;
    top: 18px;
    left: 18px;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
    background: rgba(24, 21, 20, 0.7);
    color: var(--color-white);
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .fmt-card__body {
    padding: 26px 28px 28px;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
  }

  .fmt-card__eyebrow {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--color-warm-deep);
    margin: 0;
  }

  .fmt-card h3 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1.6rem;
    line-height: 1.2;
    letter-spacing: var(--ls-tight);
    color: var(--color-text);
    margin: 0;
  }

  .fmt-card__description {
    color: var(--color-text-muted);
    font-size: 1rem;
    line-height: 1.7;
    margin: 0;
  }

  .fmt-card__foot {
    margin-top: auto;
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .fmt-card__foot .arrow-link {
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .fmt-card:hover .fmt-card__foot .arrow-link {
    color: var(--color-warm-deep);
  }

  .fmt-card:hover .fmt-card__foot .arrow-link svg {
    transform: translateX(3px);
  }
</style>
