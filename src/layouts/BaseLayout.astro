---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  bodyClass?: string;
}

const {
  title = "Rangeway · Travel farther, stop better.",
  description = "America's first hospitality-driven EV charging network. Designed by hospitality operators, with the stop as the product.",
  image = "/images/waystation-hawaii.jpg",
  bodyClass = ""
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site).toString()} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Rangeway" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&family=Source+Sans+3:wght@300;400;600;700&display=swap"
    />

    <script is:inline defer src="https://tinylytics.app/embed/9_N5xEnQSTdibXFSDoqf.js"></script>
  </head>
  <body class={bodyClass}>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <style is:global>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 12px;
        background: var(--color-charcoal);
        color: var(--color-cream);
        padding: 8px 14px;
        border-radius: 4px;
        z-index: 100;
        font-family: var(--font-heading);
        font-size: 0.85rem;
      }
      .skip-link:focus {
        top: 12px;
      }
      body {
        padding-top: 0;
      }
      body:not(.has-hero) main {
        padding-top: calc(var(--nav-height) + 24px);
      }
    </style>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -60px 0px" }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
