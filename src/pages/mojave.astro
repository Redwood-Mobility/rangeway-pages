---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout
  title="Rangeway Mojave · The First Rangeway Location"
  description="Off-grid, solar-powered ultra-fast EV charging is coming to the CA-14 corridor in the Antelope Valley. Rangeway Mojave is the first location, with launch coming in 2027."
  image="/images/basecamp-rosamond.jpg"
>
  <PageHero
    eyebrow="The First Rangeway Location"
    title="Rangeway Mojave."
    lede="Off-grid, solar-powered ultra-fast charging on the CA-14 corridor, with launch coming in 2027."
    image="/images/basecamp-rosamond.jpg"
    imageAlt="Aerial view of Rangeway Mojave at dusk with solar canopy, battery storage, and charging plaza beside the highway"
    align="left"
    scrim="strong"
  >
    <div class="mojave-hero__ctas">
      <a class="btn btn-warm" href="https://mojave.rangewayev.com" target="_blank" rel="noopener">
        Visit the microsite
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="13 6 19 12 13 18" />
        </svg>
      </a>
      <a class="btn btn-ghost" href="https://fieldnotes.rangewayev.com" target="_blank" rel="noopener">
        Subscribe to Field Notes
      </a>
    </div>
  </PageHero>

  <section class="section">
    <div class="container-narrow prose-lg reveal">
      <p class="eyebrow">Why here</p>
      <h2>The corridor that's been waiting.</h2>
      <p>
        The CA-14 corridor connects the Los Angeles basin to the high desert and points north. It is the daily commute for the aerospace and defense workforce at Edwards Air Force Base, Northrop Grumman, Lockheed Martin, Boeing, NASA, and Virgin Galactic, and on weekends, it carries travelers heading to the Eastern Sierra and beyond.
      </p>
      <p>
        Right now, those drivers have nowhere to charge in a place worth waiting in. Rangeway Mojave changes that.
      </p>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow reveal">
      <p class="eyebrow">Phase I</p>
      <h2>Built from the ground up. Powered by the sun.</h2>
      <p class="prose-lg">
        Phase I delivers ultra-fast charging under a custom timber canopy, powered entirely by an on-site solar array and battery energy storage system. The entire site operates independently of the electrical grid, engineered by <a href="https://carbondc.io" target="_blank" rel="noopener">Carbon DC</a>, whose off-grid platform is already operating at multiple sites across California's desert corridors.
      </p>
      <p class="prose-lg">
        Fresh food and drinks are served from our on-site Rivian EDV food truck, with desert-native landscaping and shaded seating that round out the experience.
      </p>
      <p class="prose-lg muted">
        Phase II brings the full Rangeway experience: a climate-controlled driver's lounge with a staffed cafe, comfortable seating, comfortable restrooms, and on-site coffee roasting from <a href="https://redcanyonroasting.co" target="_blank" rel="noopener">Red Canyon Roasting Company</a>. The lounge is coming shortly after launch.
      </p>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container-narrow text-center reveal">
      <p class="eyebrow eyebrow-muted" style="color: var(--color-warm);">Read the full story</p>
      <h2>Every network starts with one site. This is ours.</h2>
      <p class="prose-lg" style="margin-top: var(--space-5); opacity: 0.85;">
        Visit the Rangeway Mojave microsite for the full story: site stats, how the off-grid platform works, the vision behind the network, and how to follow construction progress.
      </p>
      <div style="margin-top: var(--space-7); display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
        <a class="btn btn-warm" href="https://mojave.rangewayev.com" target="_blank" rel="noopener">
          Visit Rangeway Mojave
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </a>
        <a class="btn btn-ghost" href="/network">Explore the Network</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .mojave-hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
</style>
