---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const partners = [
  {
    name: "Carbon DC",
    role: "Energy infrastructure",
    description:
      "Our partner on behind-the-meter energy systems. Carbon DC designs and delivers the power architecture that makes premium sites feasible, including utility interconnect, battery, and solar integration.",
    href: "https://carbondc.io",
    logo: "/images/partners/carbondc.png"
  },
  {
    name: "ChargeMate",
    role: "24/7 AI driver support",
    description:
      "The always-on concierge for every Rangeway site. ChargeMate combines AI-led troubleshooting with escalation to real Trailkeepers, so no driver is ever stuck.",
    href: "https://chargemate.ai",
    logo: "/images/partners/chargemate.jpg"
  },
  {
    name: "Ekoenergetyka",
    role: "Ultra-fast charging hardware",
    description:
      "European engineering for the chargers at the core of the experience. Ekoenergetyka hardware is chosen for reliability, service life, and a design language worthy of a hospitality-forward site.",
    href: "https://ekoenergetyka.com/america/",
    logo: "/images/partners/ekoenergetyka.png"
  },
  {
    name: "HyWatts",
    role: "Modular off-grid power systems",
    description:
      "Modular Power-Plant-in-a-Box systems that integrate solar, battery storage, and hydrogen-ready generation. HyWatts enables grid-independent operation at sites where utility interconnection is slow, expensive, or unavailable.",
    href: "https://hywatts.com",
    logo: "/images/partners/hywatts.webp"
  },
  {
    name: "Juice",
    role: "Plug-and-charge technology",
    description:
      "Seamless authentication and session handling. Juice powers the plug-and-charge experience that lets drivers arrive, plug in, and go, without apps or friction.",
    href: "https://js.eco",
    logo: "/images/partners/juice.png"
  },
  {
    name: "Monta",
    role: "Charge point management",
    description:
      "The software layer that runs the chargers. Monta handles payments, roaming, uptime monitoring, and the operational backbone that keeps every stall reliable.",
    href: "https://monta.com",
    logo: "/images/partners/monta.png"
  },
  {
    name: "ReNuTeq",
    role: "Structural and building partner",
    description:
      "Purpose-built structures for every Rangeway format. ReNuTeq helps us ship high-quality canopies, lounges, and supporting buildings faster than traditional construction allows.",
    href: "https://renuteq.com",
    logo: "/images/partners/renuteq.jpg"
  },
  {
    name: "WattsUp",
    role: "Predictive maintenance",
    description:
      "The quiet work of staying reliable. WattsUp analyzes charger telemetry to anticipate failures before drivers ever feel them, keeping uptime where hospitality expects it.",
    href: "https://wattsupev.io/",
    logo: "/images/partners/wattsup.png"
  }
];
---

<BaseLayout
  title="Partners · Rangeway"
  description="The partners building Rangeway. Energy infrastructure, hardware, structures, software, and support."
  image="/images/waystation-exterior.png"
>
  <PageHero
    eyebrow="Partners"
    title="Built with the best."
    lede="Rangeway is a brand and an operating company. The partners listed here build the systems behind the experience."
    image="/images/waystation-exterior.png"
    imageAlt="A Waystation in warm evening light"
  />

  <section class="section">
    <div class="container">
      <ul class="partners-list">
        {partners.map((p, i) => (
          <li class="partner-row reveal">
            <div class="partner-row__label">
              <span class="partner-row__num">/{String(i + 1).padStart(2, "0")}</span>
              <div class="partner-row__mark">
                {p.logo && <img src={p.logo} alt={`${p.name} logo`} loading="lazy" />}
              </div>
              <div>
                <h3>{p.name}</h3>
                <p class="partner-row__role">{p.role}</p>
              </div>
            </div>
            <div class="partner-row__body">
              <p>{p.description}</p>
              <a class="btn-link" href={p.href} target="_blank" rel="noopener">
                Visit {p.name}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 17L17 7" />
                  <polyline points="7 7 17 7 17 17" />
                </svg>
              </a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow text-center reveal">
      <p class="eyebrow">Partner with Rangeway</p>
      <h2>Want to work with us?</h2>
      <p class="prose-lg muted" style="margin-top: var(--space-4);">
        We are always looking for hospitality operators, real estate partners, technology providers,
        and energy companies who share the conviction that charging should be better.
      </p>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn-primary" href="mailto:partners@rangewayev.com?subject=Partnership%20Inquiry">
          Email partners@rangewayev.com
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .partners-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .partner-row {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-8);
    padding: var(--space-7) 0;
    border-bottom: 1px solid var(--color-border);
    align-items: start;
  }

  .partner-row:first-child {
    border-top: 1px solid var(--color-border);
  }

  .partner-row__label {
    display: flex;
    gap: var(--space-4);
    align-items: center;
  }

  .partner-row__mark {
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--surface-alt);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .partner-row__mark img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .partner-row__num {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: var(--color-warm-deep);
    font-weight: 600;
  }

  .partner-row h3 {
    font-size: clamp(1.6rem, 2.4vw, 2rem);
    font-weight: 700;
    margin: 0;
  }

  .partner-row__role {
    font-family: var(--font-heading);
    font-size: 0.82rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: var(--space-2) 0 0;
  }

  .partner-row__body p {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  @media (max-width: 780px) {
    .partner-row {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
</style>
