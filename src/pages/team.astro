---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const team = [
  {
    name: "Zak Winnick",
    role: "Founder and CEO",
    bio: "Zak has spent his career operating luxury resorts, wellness retreats, and flagship urban hotels. He is also a longtime EV driver, community organizer, and podcast host, with firsthand insight into what charging actually feels like on a long trip.",
    photo: "/images/team/zak-winnick.jpg",
    linkedin: "https://www.linkedin.com/in/zakwinnick"
  },
  {
    name: "Theo Reichgelt",
    role: "Brand and Growth",
    bio: "Theo founded Nexxt Industry, Europe's leading eMobility marketing agency, and specializes in charging network brand development and market positioning. He also hosts The eMobility Marketing Podcast.",
    photo: "/images/team/theo-reichgelt.jpg",
    linkedin: "https://www.linkedin.com/in/theoreichgelt/"
  },
  {
    name: "James Regan",
    role: "Finance and Strategy",
    bio: "James has built his career in corporate development and business analytics, and serves as Managing Partner at CapitalWorks. He specializes in infrastructure project financing and capital strategy for the buildout of the Rangeway network.",
    photo: "/images/team/james-regan.jpg",
    linkedin: "https://www.linkedin.com/in/james-regan-913915a/"
  },
  {
    name: "Stephanie McGreevy",
    role: "Policy and Public Capital",
    bio: "Stephanie's career has been in zero-emission vehicle infrastructure, and she is the founder of Open Energy Alliance. She specializes in LCFS optimization and grant funding strategies, including NEVI and state-level incentive programs.",
    photo: "/images/team/stephanie-mcgreevy.jpg",
    linkedin: "https://www.linkedin.com/in/smcgreevy/"
  }
];
---

<BaseLayout
  title="Team · Rangeway"
  description="The people building Rangeway. Hospitality operators, energy veterans, and EV community organizers."
  image="/images/basecamp-interior.jpg"
>
  <PageHero
    eyebrow="Team"
    title="The people behind Rangeway."
    lede="Every decision in this company is made by someone who has run a real property for real guests, or driven a real EV on a real road trip. Usually both."
    image="/images/basecamp-interior.jpg"
    imageAlt="Warm interior of a Rangeway driver's lounge"
  />

  <section class="section">
    <div class="container">
      <div class="reveal" style="max-width: 620px; margin-bottom: var(--space-7);">
        <p class="eyebrow">Team</p>
        <h2>The people behind the network.</h2>
      </div>
      <ul class="team-grid">
        {team.map((m) => (
          <li class="team-card reveal">
            <div class="team-card__photo">
              <img src={m.photo} alt={`Portrait of ${m.name}`} loading="lazy" />
            </div>
            <div class="team-card__body">
              <h3>{m.name}</h3>
              <p class="team-card__role">{m.role}</p>
              <p class="team-card__bio">{m.bio}</p>
              <a
                class="team-card__linkedin"
                href={m.linkedin}
                target="_blank"
                rel="noopener"
                aria-label={`${m.name} on LinkedIn`}
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M4.98 3.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.06c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.77 2.65 4.77 6.1V21h-4v-5.4c0-1.3-.03-2.98-1.82-2.98-1.82 0-2.1 1.42-2.1 2.88V21h-4V9z" />
                </svg>
                <span>LinkedIn</span>
              </a>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow text-center reveal">
      <p class="eyebrow">Join us</p>
      <h2>We are hiring.</h2>
      <p class="prose-lg muted" style="margin-top: var(--space-4);">
        Rangeway is looking for hospitality operators, site leads, energy engineers, and people who
        care about how a good stop feels. If the thesis rings true, we want to hear from you.
      </p>
      <div class="hiring-ctas">
        <a class="btn btn-primary" href="mailto:careers@rangeway.co?subject=Joining%20Rangeway">
          Email careers@rangeway.co
        </a>
        <a
          class="btn btn-outline"
          href="https://www.linkedin.com/company/rangewayenergy/jobs/"
          target="_blank"
          rel="noopener noreferrer"
        >
          View LinkedIn jobs
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hiring-ctas {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--space-6);
  }

  .team-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .team-grid--single {
    grid-template-columns: 1fr;
  }

  .team-grid--single .team-card {
    max-width: 760px;
  }

  .team-card {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    align-items: flex-start;
  }

  .team-card--placeholder {
    background: var(--surface-alt);
    border-style: dashed;
  }

  .team-card__photo {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--surface-alt);
  }

  .team-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .team-card h3 {
    font-size: 1.3rem;
    margin: 0;
  }

  .team-card__role {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-warm-deep);
    font-weight: 600;
    margin: var(--space-2) 0 var(--space-4);
  }

  .team-card--placeholder .team-card__role {
    color: var(--color-text-muted);
  }

  .team-card__bio {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  .team-card__linkedin {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .team-card__linkedin:hover {
    color: var(--color-warm-deep);
  }

  .team-card--placeholder .team-card__bio {
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 900px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
    .team-card {
      flex-direction: column;
    }
  }
</style>
