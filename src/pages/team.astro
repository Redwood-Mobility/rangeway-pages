---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const team = [
  {
    name: "Zak Winnick",
    role: "Founder and CEO",
    bio: "Hospitality operator with over 15 years at premium properties including Wynn Las Vegas, the Cosmopolitan of Las Vegas, Grand Hyatt Nashville, and Sensei. Community Director of the Bay Area Rivian Club, co-founder of NorCal EVs, and host of the Trail Marker Podcast and the Rivian Clubs of America Podcast.",
    affiliations: [
      "Bay Area Rivian Club",
      "NorCal EVs",
      "Trail Marker Podcast",
      "Rivian Clubs of America Podcast"
    ],
    photo: "/images/team/zak-winnick.jpg"
  },
  {
    name: "Theo Reichgelt",
    role: "Brand and Growth",
    bio: "Founder of Nexxt Industry, Europe's leading eMobility marketing agency. Over eight years specializing in charging network brand development and market positioning. Host of The eMobility Marketing Podcast.",
    affiliations: [
      "Nexxt Industry",
      "The eMobility Marketing Podcast"
    ],
    photo: "/images/team/theo-reichgelt.jpg"
  },
  {
    name: "James Regan",
    role: "Finance and Strategy",
    bio: "Over 30 years in corporate development and business analytics. Managing Partner at CapitalWorks. Expert in infrastructure project financing and capital strategy for the buildout of the Rangeway network.",
    affiliations: ["CapitalWorks"],
    photo: "/images/team/james-regan.jpg"
  },
  {
    name: "Stephanie McGreevy",
    role: "Policy and Public Capital",
    bio: "Over 15 years in zero-emission vehicle infrastructure. Founder of Open Energy Alliance. Specializes in LCFS optimization and grant funding strategies, including NEVI and state-level incentive programs.",
    affiliations: ["Open Energy Alliance"],
    photo: "/images/team/stephanie-mcgreevy.jpg"
  }
];
---

<BaseLayout
  title="Team · Rangeway"
  description="The people building Rangeway. Hospitality operators, energy veterans, and EV community organizers."
  image="/images/basecamp-interior.jpg"
>
  <PageHero
    eyebrow="Team"
    title="The people behind Rangeway."
    lede="Every decision in this company is made by someone who has run a real property for real guests, or driven a real EV on a real road trip. Usually both."
    image="/images/basecamp-interior.jpg"
    imageAlt="Warm interior of a Rangeway driver's lounge"
  />

  <section class="section">
    <div class="container">
      <div class="reveal" style="max-width: 620px; margin-bottom: var(--space-7);">
        <p class="eyebrow">Team</p>
        <h2>The people behind the network.</h2>
      </div>
      <ul class="team-grid">
        {team.map((m) => (
          <li class="team-card reveal">
            <div class="team-card__photo">
              <img src={m.photo} alt={`Portrait of ${m.name}`} loading="lazy" />
            </div>
            <div class="team-card__body">
              <h3>{m.name}</h3>
              <p class="team-card__role">{m.role}</p>
              <p class="team-card__bio">{m.bio}</p>
              <ul class="team-card__affiliations">
                {m.affiliations.map((a) => <li>{a}</li>)}
              </ul>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container-narrow text-center reveal">
      <p class="eyebrow">Join us</p>
      <h2>We are hiring.</h2>
      <p class="prose-lg muted" style="margin-top: var(--space-4);">
        Rangeway is looking for hospitality operators, site leads, energy engineers, and people who
        care about how a good stop feels. If the thesis rings true, we want to hear from you.
      </p>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn-primary" href="mailto:careers@rangewayev.com?subject=Joining%20Rangeway">
          Email careers@rangewayev.com
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .team-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .team-grid--single {
    grid-template-columns: 1fr;
  }

  .team-grid--single .team-card {
    max-width: 760px;
  }

  .team-card {
    display: flex;
    gap: var(--space-5);
    padding: var(--space-6);
    background: var(--surface-raised);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    align-items: flex-start;
  }

  .team-card--placeholder {
    background: var(--surface-alt);
    border-style: dashed;
  }

  .team-card__photo {
    flex-shrink: 0;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--surface-alt);
    box-shadow: 0 4px 16px rgba(24, 18, 14, 0.08);
  }

  .team-card__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .team-card h3 {
    font-size: 1.3rem;
    margin: 0;
  }

  .team-card__role {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-warm-deep);
    font-weight: 600;
    margin: var(--space-2) 0 var(--space-4);
  }

  .team-card--placeholder .team-card__role {
    color: var(--color-text-muted);
  }

  .team-card__bio {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  .team-card--placeholder .team-card__bio {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .team-card__affiliations {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .team-card__affiliations li {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
  }

  @media (max-width: 900px) {
    .team-grid {
      grid-template-columns: 1fr;
    }
    .team-card {
      flex-direction: column;
    }
  }
</style>
