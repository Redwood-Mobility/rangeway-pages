---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import FormatNav from "../../components/FormatNav.astro";

const amenities = [
  { title: "Ten to twelve ultra-fast chargers", body: "Flagship capacity for the highest-traffic corridors. Designed for steady throughput and peak weekends alike." },
  { title: "2,500 square foot staffed driver's lounge", body: "Our most generous indoor space. Seating zones for work, for family, for quiet." },
  { title: "Staffed cafe", body: "A real kitchen with a real menu. Local coffee, warm food, hospitality in the room." },
  { title: "Trailkeepers on site", body: "Hospitality staff trained to help, not just to supervise. The difference is felt the moment you walk in." },
  { title: "Extended hours", body: "Built for the full arc of the day. Early mornings, late nights, long holiday weekends." },
  { title: "Amenities for families and travelers", body: "Play corners, nursing rooms, pet-friendly patios. The stops our guests will remember." }
];
---

<BaseLayout
  title="Basecamp · The Network"
  description="The full-service destination. Ten to twelve ultra-fast chargers, a 2,500 square foot staffed driver's lounge, and a staffed cafe."
  image="/images/basecamp-hero.jpg"
>
  <PageHero
    eyebrow="Basecamp"
    title="The full-service destination."
    lede="Our flagship experience. Ten to twelve chargers, a staffed driver's lounge, a staffed cafe, and the people who make it all feel effortless."
    image="/images/basecamp-hero.jpg"
    imageAlt="A Basecamp exterior with warm evening light"
  />

  <FormatNav current="basecamp" />

  <section class="section">
    <div class="container format-intro">
      <div class="reveal">
        <p class="eyebrow">What a Basecamp is</p>
        <h2>Hospitality at full scale.</h2>
      </div>
      <div class="format-intro__body reveal">
        <p class="prose-lg">
          Basecamp is what happens when we stop apologizing for charging stops. It is an actual
          destination, staffed by people who know your name before you leave, placed on corridors
          where the traffic earns the full experience.
        </p>
        <p class="prose-lg muted">
          Everything we have learned about hospitality at premium properties shows up here. The
          cafe is real. The service is real. The comfort is real. The chargers happen to be
          excellent too.
        </p>
      </div>
    </div>
  </section>

  <section class="section section-cream">
    <div class="container">
      <div class="reveal" style="margin-bottom: var(--space-8); max-width: 620px;">
        <p class="eyebrow">What you'll find</p>
        <h2>A staffed, hospitality-led experience.</h2>
      </div>
      <div class="amenity-grid">
        {amenities.map((a) => (
          <article class="amenity reveal">
            <h3>{a.title}</h3>
            <p>{a.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="format-gallery section">
    <div class="container">
      <div class="gallery-grid">
        <div class="gallery-grid__item gallery-grid__item--lg reveal">
          <img src="/images/basecamp-hero.jpg" alt="Basecamp exterior with warm evening light" loading="lazy" />
        </div>
        <div class="gallery-grid__item reveal">
          <img src="/images/basecamp-alt-1.jpg" alt="Basecamp from another angle" loading="lazy" />
        </div>
        <div class="gallery-grid__item reveal">
          <img src="/images/basecamp-alt-2.jpg" alt="Basecamp site in context" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container-narrow text-center reveal">
      <p class="eyebrow eyebrow-muted" style="color: var(--color-warm);">One step further</p>
      <h2>For the journey that should last overnight, there is Summit.</h2>
      <p class="prose-lg" style="margin-top: var(--space-5); opacity: 0.85;">
        Modular Lookouts, a central clubhouse, 100% off-grid solar charging. The stop becomes the
        trip.
      </p>
      <div style="margin-top: var(--space-6);">
        <a class="btn btn-warm" href="/summit">
          Explore Summit
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="13 6 19 12 13 18" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .format-intro {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-8);
    align-items: start;
  }

  .format-intro__body p {
    font-size: 1.15rem;
    line-height: 1.7;
  }

  .amenity-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .amenity {
    background: var(--surface-raised);
    padding: var(--space-6);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .amenity h3 {
    font-size: 1.2rem;
    margin-bottom: var(--space-3);
  }

  .amenity p {
    color: var(--color-text-muted);
    margin: 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: repeat(2, 280px);
    gap: var(--space-4);
  }

  .gallery-grid__item {
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .gallery-grid__item--lg {
    grid-row: span 2;
  }

  .gallery-grid__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .format-intro,
    .amenity-grid {
      grid-template-columns: 1fr;
    }
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(3, 240px);
    }
    .gallery-grid__item--lg {
      grid-row: auto;
    }
  }
</style>
